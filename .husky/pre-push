# Branch guard — block direct pushes to develop or main.
# Parses Git stdin refspecs so that deletions and pushes to any
# other remote ref are never blocked, even when HEAD is develop or main.
# Stories 45 + 53. Override for declared hotfixes only.
ZERO="0000000000000000000000000000000000000000"

while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue
  if [ "$remote_ref" = "refs/heads/develop" ] || [ "$remote_ref" = "refs/heads/main" ]; then
    if [ "$ALLOW_DIRECT_PUSH" != "1" ]; then
      echo ""
      echo "❌ Direct push to '${remote_ref#refs/heads/}' blocked by .husky/pre-push."
      echo "   Use a feature branch: git checkout -b feature/your-change-name"
      echo "   Then PR feature → develop → main."
      echo ""
      echo "   Emergency override (rare — declared hotfixes only):"
      echo "     ALLOW_DIRECT_PUSH=1 git push"
      echo ""
      exit 1
    fi
  fi
done

# Run frontend tests before allowing push.
# No retry — first run must succeed. See ROADMAP Story 32.
cd frontend && npm test
